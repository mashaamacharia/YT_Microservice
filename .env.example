# ─────────────────────────────────────────────────────────────
# YouTube Pipeline — LLM Service Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# .env is gitignored. This file (.env.example) is safe to commit.
# ─────────────────────────────────────────────────────────────


# ─── Provider Priority ────────────────────────────────────────
# Order in which providers are tried. First available key wins.
# Providers with no API key are silently skipped.
# Change the order to make a different provider primary.
LLM_PROVIDER_ORDER=anthropic,openai,gemini


# ─── API Keys ─────────────────────────────────────────────────
# Only fill in the keys you actually have.
# Leave others empty or commented — they will be skipped.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=


# ─── Models: RESEARCH task ────────────────────────────────────
# Used in Phase 2 — aggregates YouTube + Reddit + Trends
# into 5 video ideas. Needs good reasoning, not heavy.
RESEARCH_MODEL_ANTHROPIC=claude-sonnet-4-6
RESEARCH_MODEL_OPENAI=gpt-4o-mini
RESEARCH_MODEL_GEMINI=gemini-1.5-flash


# ─── Models: SCRIPT task ──────────────────────────────────────
# Used in Phase 4 — generates full 5-minute video script.
# Most demanding task — use the best model you have.
SCRIPT_MODEL_ANTHROPIC=claude-sonnet-4-6
SCRIPT_MODEL_OPENAI=gpt-4o
SCRIPT_MODEL_GEMINI=gemini-1.5-pro


# ─── Models: ANALYTICS task ───────────────────────────────────
# Used in Phase 13 — interprets YouTube performance metrics.
# Simple summarization — cheapest/fastest model is fine.
ANALYTICS_MODEL_ANTHROPIC=claude-haiku-4-5-20251001
ANALYTICS_MODEL_OPENAI=gpt-4o-mini
ANALYTICS_MODEL_GEMINI=gemini-1.5-flash


# ─── Models: KEYWORDS task ────────────────────────────────────
# Used in Phase 7 — generates fallback stock footage keywords.
# Tiny task — cheapest model always.
KEYWORDS_MODEL_ANTHROPIC=claude-haiku-4-5-20251001
KEYWORDS_MODEL_OPENAI=gpt-4o-mini
KEYWORDS_MODEL_GEMINI=gemini-1.5-flash


# ─── Token Limits ─────────────────────────────────────────────
# Max tokens the LLM can return per task.
# Increase SCRIPT_MAX_TOKENS if scripts are getting cut off.
RESEARCH_MAX_TOKENS=1000
SCRIPT_MAX_TOKENS=4000
ANALYTICS_MAX_TOKENS=500
KEYWORDS_MAX_TOKENS=200


# ─── Timeouts ─────────────────────────────────────────────────
# How long to wait for a provider before marking it failed
# and trying the next one. In seconds.
LLM_TIMEOUT_SECONDS=30


# ─── Service ──────────────────────────────────────────────────
PORT=8001
ENVIRONMENT=development
LOG_LEVEL=info
